        <mxCell id="optionType" value="&lt;b&gt;OptionType&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#6B7280&quot;&gt;&amp;lt;&amp;lt;enumeration&amp;gt;&amp;gt;&lt;/font&gt;&lt;hr&gt;CALL&lt;br&gt;PUT" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;strokeColor=#6B7280;fillColor=#F9FAFB;fontColor=#111827;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="700" width="170" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="extensionNote" value="&lt;b&gt;Extension point&lt;/b&gt;&lt;br&gt;To add a component:&lt;br&gt;1. Add its enum value&lt;br&gt;2. Add its calculation method&lt;br&gt;3. Add one registry definition&lt;br&gt;4. Declare extra ParameterSpecs&lt;br&gt;&lt;br&gt;Manager and UI remain branch-free." style="shape=note;whiteSpace=wrap;html=1;size=18;align=left;verticalAlign=top;spacing=12;strokeColor=#D97706;fillColor=#FEF3C7;fontColor=#78350F;fontSize=12;" vertex="1" parent="1">
